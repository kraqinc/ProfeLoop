<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.profeloop.kalanba.home.HomeFragment"
        android:label="ProfeLoop"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_subjectList"
            app:destination="@id/subjectListFragment" />
    </fragment>

    <fragment
        android:id="@+id/subjectListFragment"
        android:name="com.profeloop.kalanba.subjects.SubjectListFragment"
        android:label="Materias"
        tools:layout="@layout/fragment_subject_list">
        <argument
            android:name="extra_grado"
            app:argType="integer"
            android:defaultValue="1" />
        <action
            android:id="@+id/action_subjectList_to_taskList"
            app:destination="@id/taskListFragment" />
    </fragment>

    <fragment
        android:id="@+id/taskListFragment"
        android:name="com.profeloop.kalanba.tasks.TaskListFragment"
        android:label="Tareas"
        tools:layout="@layout/fragment_task_list">
        <argument
            android:name="extra_grado"
            app:argType="integer"
            android:defaultValue="1" />
        <argument
            android:name="extra_asignatura"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="extra_periodo"
            app:argType="integer"
            android:defaultValue="1" />
    </fragment>

    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.profeloop.kalanba.notifications.NotificationsFragment"
        android:label="Notificaciones"
        tools:layout="@layout/fragment_notifications" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.profeloop.kalanba.profile.ProfileFragment"
        android:label="Mi perfil"
        tools:layout="@layout/fragment_profile" />

</navigation>
