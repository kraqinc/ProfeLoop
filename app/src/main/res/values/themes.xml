<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TareaApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorOnPrimary">@color/md_theme_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_onPrimaryContainer</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/md_theme_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_onSecondaryContainer</item>

        <!-- Tertiary brand color -->
        <item name="colorTertiary">@color/md_theme_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_onTertiary</item>

        <!-- Error color -->
        <item name="colorError">@color/md_theme_error</item>
        <item name="colorOnError">@color/md_theme_onError</item>

        <!-- Background / Surface -->
        <item name="android:colorBackground">@color/md_theme_background</item>
        <item name="colorSurface">@color/md_theme_surface</item>
        <item name="colorOnSurface">@color/md_theme_onSurface</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_onSurfaceVariant</item>
        <item name="colorOutline">@color/md_theme_outline</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/md_theme_primary</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Action bar -->
        <item name="actionBarTheme">@style/ThemeOverlay.TareaApp.ActionBar</item>

        <!-- Premium styles -->
        <item name="materialButtonStyle">@style/PremiumButtonStyle</item>
        <item name="materialCardViewStyle">@style/PremiumCardStyle</item>
    </style>

    <style name="PremiumButtonStyle" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/btn_gradient</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Premium.Button</item>
    </style>

    <style name="PremiumCardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">8dp</item>
        <item name="cardCornerRadius">28dp</item>
        <item name="cardBackgroundColor">@color/card_bg_premium</item>
    </style>

    <style name="ShapeAppearance.Premium.Button" parent="">
        <item name="cornerSize">24dp</item>
    </style>

    <style name="PremiumChatText" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/md_theme_onPrimary</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="ThemeOverlay.TareaApp.ActionBar" parent="ThemeOverlay.Material3.ActionBar">
        <item name="colorControlNormal">@color/md_theme_onPrimary</item>
        <item name="android:textColorPrimary">@color/md_theme_onPrimary</item>
    </style>

    <!-- Splash / Launch screen -->
    <style name="Theme.TareaApp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/md_theme_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.TareaApp</item>
    </style>

</resources>
